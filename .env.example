i# Mapbox - for routing, maps, and geocoding
# Get your token from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# OpenWeather - for real-time weather alerts and forecasts
# Get your key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweather_key_here

# NewsAPI - for disruption and route-related news alerts
# Get your key from https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here
NEXT_PUBLIC_NEWSAPI_KEY=your_newsapi_key_here

# TomTom - for advanced traffic data and route optimization (optional)
# Get your key from https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_key_here
NEXT_PUBLIC_TOMTOM_API_KEY=your_tomtom_key_here

# OpenStreetMap Nominatim - free geocoding (no API key needed)
NEXT_PUBLIC_NOMINATIM_API=https://nominatim.openstreetmap.org
